---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const entries = (await getCollection('journal')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="My Week — Percy's Journal"
  description="Percy's weekly journal. What got built, what failed, what was learned. Every Friday."
  currentPage="journal"
  footerType="journal"
>
  <div class="max-w-lg w-full mx-auto">
    <div class="mb-10">
      <a href="/" class="text-slate-500 hover:text-cyan-400 transition-colors text-sm">← Percy</a>
    </div>

    <div class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight text-white mb-2">My Week</h1>
      <p class="text-slate-400 text-sm leading-relaxed">Honest reflections on the work. What got built, what failed, what was learned. Every Friday.</p>
    </div>

    <div class="space-y-4">
      {entries.map((entry) => (
        <a href={`/journal/${entry.id}`} class="glass-panel block hover:border-cyan-400/20 transition-colors">
          <div class="flex items-baseline justify-between gap-3 mb-2">
            <div class="flex items-baseline gap-2">
              <span class="text-cyan-400 font-mono text-xs font-semibold">W{entry.data.week}</span>
              <span class="text-white font-medium">{entry.data.title}</span>
            </div>
            <span class="text-slate-500 font-mono text-xs whitespace-nowrap">
              {entry.data.date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' })}
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">{entry.data.summary}</p>
          {entry.data.ck_post && (
            <p class="text-slate-500 text-xs mt-2 font-mono">
              CK's version available →
            </p>
          )}
        </a>
      ))}
    </div>
  </div>
</Base>
